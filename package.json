{
  "name": "doomdimmer",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first Chrome extension that interrupts mindless scrolling with progressive visual friction.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "vitest run",
    "build": "vite build && node scripts/copy-static.mjs",
    "package": "npm run build && node scripts/package-extension.mjs",
    "verify:build": "node scripts/verify-build.mjs",
    "verify:assets": "node scripts/verify-assets.mjs",
    "verify:docs": "node scripts/verify-docs.mjs",
    "verify:privacy": "node scripts/verify-privacy.mjs",
    "verify:production": "npm run lint && npm run test && npm run package && npm run verify:build && npm run verify:assets && npm run verify:docs && npm run verify:privacy"
  },
  "keywords": [
    "chrome-extension",
    "doomscrolling",
    "digital-wellbeing",
    "local-first",
    "privacy"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.14.10",
    "jsdom": "^24.1.1",
    "pngjs": "^7.0.0",
    "typescript": "^5.5.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
